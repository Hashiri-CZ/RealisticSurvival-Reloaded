<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <artifactId>harshlands-dist</artifactId>
    <packaging>jar</packaging>

    <parent>
        <groupId>cz.hashiri.harshlands</groupId>
        <artifactId>harshlands-parent</artifactId>
        <version>1.3.2</version>
    </parent>

    <build>
        <directory>../target</directory>
        <finalName>harshlands-${project.version}</finalName>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-shade-plugin</artifactId>
                <version>3.6.1</version>
                <executions>
                    <execution>
                        <phase>package</phase>
                        <goals>
                            <goal>shade</goal>
                        </goals>
                        <configuration>
                            <filters>
                                <filter>
                                    <artifact>*:*</artifact>
                                    <excludes>
                                        <exclude>META-INF/**</exclude>
                                        <exclude>module-info.class</exclude>
                                        <exclude>languages/**</exclude>
                                        <exclude>schematics/**</exclude>
                                    </excludes>
                                </filter>
                                <filter>
                                    <artifact>com.h2database:h2</artifact>
                                    <excludes>
                                        <exclude>org/h2/server/web/**</exclude>
                                        <exclude>org/h2/server/pg/**</exclude>
                                    </excludes>
                                </filter>
                            </filters>
                            <artifactSet>
                                <includes>
                                    <include>cz.hashiri.harshlands:harshlands-core</include>
                                    <include>cz.hashiri.harshlands:harshlands-spigot_impl_1_21_R11</include>
                                    <include>cz.hashiri.harshlands:harshlands-spigot_impl_26_1_R1</include>
                                    <include>com.zaxxer:HikariCP</include>
                                    <include>com.h2database:h2</include>
                                </includes>
                            </artifactSet>
                            <relocations>
                                <relocation>
                                    <pattern>com.zaxxer.hikari</pattern>
                                    <shadedPattern>cz.hashiri.harshlands.libs.hikari</shadedPattern>
                                </relocation>
                                <relocation>
                                    <pattern>org.h2</pattern>
                                    <shadedPattern>cz.hashiri.harshlands.libs.h2</shadedPattern>
                                </relocation>
                            </relocations>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>

    <dependencies>
        <dependency>
            <groupId>cz.hashiri.harshlands</groupId>
            <artifactId>harshlands-core</artifactId>
            <version>${project.parent.version}</version>
        </dependency>
        <dependency>
            <groupId>cz.hashiri.harshlands</groupId>
            <artifactId>harshlands-spigot_impl_1_21_R11</artifactId>
            <version>${project.parent.version}</version>
        </dependency>
        <dependency>
            <groupId>cz.hashiri.harshlands</groupId>
            <artifactId>harshlands-spigot_impl_26_1_R1</artifactId>
            <version>${project.parent.version}</version>
        </dependency>
    </dependencies>

</project>
